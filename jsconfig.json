{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "jsx": "react",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    // 🎯 A REGRA QUE IGNORA A INCONSISTÊNCIA DE CAPITALIZAÇÃO
    "forceConsistentCasingInFileNames": false 
  },
  "include": [
    "src/**/*"
  ]
}